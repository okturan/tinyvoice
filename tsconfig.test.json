{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "vitest/globals", "@cloudflare/vitest-pool-workers/types"]
  },
  "include": [
    "tests",
    "src/types/ort.d.ts",
    "vitest.config.ts",
    "worker/worker-configuration.d.ts"
  ]
}
